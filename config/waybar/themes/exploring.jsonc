// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "top",
    "margin": "3 0 0 0",
    "width": 1700,
    
    "modules-left": [
        "sway/workspaces", 
        "sway/mode",
        "sway/scratchpad"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "custom/menu",
        "backlight",
        "pulseaudio",
        "idle_inhibitor",
        "network",
        "bluetooth",
        "battery",
        "custom/power"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "disable-markup": true,
        "format": "{icon}",
        "format-icons": {
            "1": "≤░Ι╣",
            "2": "ΎΕκ",
            "3": "ΎΕι",
            "4": "\uf07c",
            "5": "ΎΗ╢",
            "6": "ΎΝ╢",
            "8": "≤░Ξ│",
            "9": "\uf013",
            "default": {
                "format": "{name}"
            }
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": [],
            "8": [],
            "9": []
	    }
        // I don't use 7, don't know why
    },
    "sway/mode": {
        "format": "<span font='Deja Vu Sans Italic'>{}</span>"
    },
    // "sway/window": {
    //     "max-length": 60,
    //     "tooltip": false
    // },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "ΎΜΤ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        },
        "tooltip": false
    },
    "tray": {
        "icon-size": 22,
        "spacing": 8,
        "icons": {
            "blueman": "bluetooth",
            "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
        }
    },
    "clock": {
        "format": "{:%d %b  %H:%M}",
        "tooltip": false
    },
    "cpu": {
        "format": "ΎΜδ",
        "on-click": "alacritty -e btop"
    },
    "backlight": {
        "format": "{icon}",
        // "format-icons": ["ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "≤░Ψρ"],                    // Phases of the moon
        "format-icons": [ "≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ", "≤░δρ"],    // Lightbulb
        "scroll-step": 10.5006, // Cos├υ strano per evitare che allo scroll dal 100% al 90% rimanga l'icona del 100
        "tooltip-format": "{percent}%"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format-icons": {
            "default": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ"],
            "charging": ["≤░λθ", "≤░λε", "≤░ΓΗ", "≤░ΓΘ", "≤░ΓΙ", "≤░λζ", "≤░ΓΚ", "≤░λη", "≤░ΓΛ", "≤░ΓΜ"]
        },
        "format": "{icon}",
        "format-charging": "{icon}",
        "format-full": "≤░ΓΖ",
        "tooltip-format": "{capacity}%"
    },
    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "≤▒γ╜",
        "format-icons": ["≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
        "format-disconnected": "≤░νχ",
        "tooltip-format": "{essid}",
        "tooltip-format-ethernet": "wired",
        "on-click": "alacritty -e nmtui",
        "on-click-right": "notify-send '≤░Φθ Connecting...'; nmcli connection up dadopiva; notify-send 'ΎΒζ   Connected'",
        "on-click-middled": "nmcli connection down dadopiva"
    },
    "bluetooth": {
        "format": "ΎΛΥ",
        "on-click": "blueman-manager",
        "tooltip-format": "{device_alias}\t({device_battery_percentage}%)"
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}",
        "format-bluetooth": "≤▒κΠ",
        "format-bluetooth-muted": "≤▒κΣ",
        "format-muted": "Ύγσ",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "hands-free": "ΎΨΡ",
            "headphone": "Ό╣α",
            "headset": "Ό╣α",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "Ύγρ", "Ύγρ", "ΎΑρ"]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "{volume}%"
    },
    "custom/power": {
        "format" : "ΎΑΣ",
		"tooltip": false,
		"on-click":"~/.config/sway/logout.sh ~/.config/sway/lock.sh"
    },
    // "custom/chatgpt": {
    //     "format": "≤▒ε╕",
    //     "on-click": "firefox --new-window https://chatgpt.com",
    //     "tooltip": false
    // },
    "custom/menu": {
        "format": "≤░ΞΚ",
        "on-click": "fuzzel --anchor top-right --x-margin 150 --y-margin 5 --lines 24 --width 13",
        "tooltip": false
    }
}
